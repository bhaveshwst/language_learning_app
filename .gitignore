# VS Code (uncomment if you never want to share launch.json / tasks)
# .vscode/

# Flutter / Dart / Pub
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication & obfuscation
app.*.symbols
app.*.map.json

# Android build outputs (root-level)
/android/app/debug
/android/app/profile
/android/app/release

# Generated by build_runner / code gen (uncomment if you regenerate locally only)
# *.g.dart
# *.freezed.dart

# --- Secrets & signing (never commit) ---
.env
.env.*
!.env.example
*.pem
*.p12
*.mobileprovision
**/secrets.json
**/*-credentials.json
**/service-account*.json

# Android signing (see also android/.gitignore)
**/key.properties
**/*.jks
**/*.keystore

# --- Firebase client configs (project IDs / keys; re-download from Firebase Console) ---
# If your team shares one Firebase app and commits these, delete the next 4 lines.
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist
/macos/Runner/GoogleService-Info.plist

# Keep Dart options generated by FlutterFire in repo unless you prefer local-only:
# /lib/firebase_options.dart

# --- OS & editors ---
Thumbs.db
ehthumbs.db
Desktop.ini
*.sublime-project
*.sublime-workspace

# --- Testing / coverage ---
test/.test_coverage.dart
coverage/

# --- macOS / Windows / Linux (extra noise at repo root) ---
*.stackdump
