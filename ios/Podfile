# Uncomment this line to define a global platform for your project
platform :ios, '15.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# zego_express_engine's download.sh does not quote paths, so it fails when the
# project directory contains spaces (e.g. "Language Learning App").
def fix_zego_express_engine_download(ios_dir)
  download_sh = File.join(ios_dir, 'download.sh')
  return unless File.exist?(download_sh)

  script = File.read(download_sh)
  patched = script
    .gsub('cd $WORKSPACE', 'cd "$WORKSPACE"')
    .gsub('[ -f $WORKSPACE/../.debugging ]', '[ -f "$WORKSPACE/../.debugging" ]')
    .gsub("grep 'ios:' $WORKSPACE/../DEPS.yaml", "grep 'ios:' \"$WORKSPACE/../DEPS.yaml\"")
    .gsub('mkdir -p $LIBSDIR', 'mkdir -p "$LIBSDIR"')
    .gsub('[ -f $LIBSDIR/VERSION.txt ] && [ -f $LIBSDIR/ZegoExpressEngine.xcframework/Info.plist ]',
           '[ -f "$LIBSDIR/VERSION.txt" ] && [ -f "$LIBSDIR/ZegoExpressEngine.xcframework/Info.plist" ]')
    .gsub('--output $LIBSDIR/sdk.zip', '--output "$LIBSDIR/sdk.zip"')
    .gsub('unzip -q -o $LIBSDIR/sdk.zip -d $LIBSDIR', 'unzip -q -o "$LIBSDIR/sdk.zip" -d "$LIBSDIR"')
    .gsub('unzip -q -o $LIBSDIR/sdk.zip -d "$LIBSDIR"', 'unzip -q -o "$LIBSDIR/sdk.zip" -d "$LIBSDIR"')
    .gsub('for file in $LIBSDIR/release/Library/*.xcframework', 'for file in "$LIBSDIR"/release/Library/*.xcframework')
    .gsub('mv "$file" $LIBSDIR', 'mv "$file" "$LIBSDIR"')
    .gsub('mv -f $LIBSDIR/release/VERSION.txt $LIBSDIR', 'mv -f "$LIBSDIR/release/VERSION.txt" "$LIBSDIR"')
    .gsub('rm -rf $LIBSDIR/release', 'rm -rf "$LIBSDIR/release"')
    .gsub('rm -f $LIBSDIR/sdk.zip', 'rm -f "$LIBSDIR/sdk.zip"')
    .gsub('rm -rf $LIBSDIR/*.xcframework', 'rm -rf "$LIBSDIR"/*.xcframework')

  File.write(download_sh, patched) if patched != script

  xcframework = File.join(ios_dir, 'libs', 'ZegoExpressEngine.xcframework', 'Info.plist')
  return if File.exist?(xcframework)

  puts '[ZEGO] Downloading native iOS SDK (project path contains spaces)...'
  success = system('sh', download_sh)
  raise '[ZEGO] Failed to download ZegoExpressEngine.xcframework' unless success && File.exist?(xcframework)
end

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Xcode 16+ can fail with "Using bridging headers with module interfaces is unsupported".
      # Disabling explicit module interfaces avoids that conflict for mixed ObjC/Swift pods.
      config.build_settings['SWIFT_ENABLE_EXPLICIT_MODULES'] = 'NO'
    end
  end

  # zego_express_engine uses `sh ${PODS_TARGET_SRCROOT}/download.sh` without quotes;
  # that breaks when the Flutter project path contains spaces.
  installer.pods_project.targets.each do |target|
    target.build_phases.each do |phase|
      next unless phase.respond_to?(:shell_script) && phase.shell_script
      phase.shell_script = phase.shell_script.gsub(
        'sh ${PODS_TARGET_SRCROOT}/download.sh',
        'sh "${PODS_TARGET_SRCROOT}/download.sh"'
      )
    end
  end

  zego_ios = File.expand_path('.symlinks/plugins/zego_express_engine/ios', __dir__)
  fix_zego_express_engine_download(zego_ios) if File.directory?(zego_ios)
end
